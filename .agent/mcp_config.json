{
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp",
                "--api-key",
                "${CONTEXT7_API_KEY}"
            ]
        },
        "shadcn": {
            "command": "npx",
            "args": [
                "shadcn@latest",
                "mcp"
            ]
        }
    }
}

// setup mcp server in  ~/.gemini/antigravity/mcp_config.json
// IMPORTANT: Set CONTEXT7_API_KEY as an environment variable. Never hardcode API keys.

