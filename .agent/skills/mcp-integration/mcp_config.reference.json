{
  "mcpServers": {
    "github-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabledTools": [
        "create_or_update_file",
        "push_files"
      ]
    },
    "GitKraken": {
      "command": "${GK_BINARY}",
      "args": [
        "mcp",
        "--host=antigravity",
        "--source=gitlens",
        "--scheme=antigravity"
      ],
      "type": "stdio",
      "disabledTools": [
        "issues_add_comment",
        "issues_assigned_to_me",
        "issues_get_detail",
        "pull_request_create",
        "pull_request_create_review",
        "pull_request_get_comments",
        "pull_request_get_detail",
        "pull_request_assigned_to_me",
        "repository_get_file_content"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    }
  }
}

// -------------------------------------------------------------
// MCP SERVER ROLES & DEDUPLICATION:
//
// 1. github-mcp-server: Handles ALL remote/social interactions
//    (Issues, Pull Requests, remote file search, user search).
//    We disable `create_or_update_file` and `push_files` so the AI
//    only edits files locally and tests before using git_push.
//
// 2. GitKraken: Handles all local IDE Git state (status, blame,
//    log, worktree) and AI hand-off via GitLens (commit_composer,
//    launchpad, start_work).
//    We STRICTLY disable all issue/PR duplicate tools here to
//    force the AI to route through the GitHub MCP server for those.
//
// 3. context7: Global documentation indexing and querying.
//
// PATH NOTES:
// - Set GK_BINARY to your path.
//   Windows standard: "c:\\Users\\<your_user>\\AppData\\Roaming\\...\\gk.exe"
// - Never commit real API tokens into this file.
// -------------------------------------------------------------
