{
  "mcpServers": {
    "github-mcp-server": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "disabledTools": [
        "create_or_update_file",
        "push_files"
      ]
    },
    "GitKraken": {
      "command": "${GK_BINARY}",
      "args": [
        "mcp",
        "--host=antigravity",
        "--source=gitlens",
        "--scheme=antigravity"
      ],
      "type": "stdio",
      "disabledTools": [
        "issues_add_comment",
        "issues_assigned_to_me",
        "issues_get_detail",
        "pull_request_create",
        "pull_request_create_review",
        "pull_request_get_comments",
        "pull_request_get_detail",
        "pull_request_assigned_to_me",
        "repository_get_file_content"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    }
  }
}
